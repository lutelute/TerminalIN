{
  "name": "tin",
  "version": "1.3.1",
  "description": "Terminal workspace manager for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --mac",
    "predist": "npx node-gyp rebuild",
    "prebuild": "npx node-gyp rebuild",
    "dist": "electron-builder --mac --publish never"
  },
  "keywords": [],
  "author": "shigenoburyuto",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.shigenoburyuto.tin",
    "productName": "TiN",
    "afterPack": "scripts/clean-xattr.js",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dir",
          "arch": "arm64"
        },
        {
          "target": "zip",
          "arch": "arm64"
        }
      ],
      "identity": null,
      "icon": "icon.icns",
      "protocols": [
        {
          "name": "TiN URL",
          "schemes": [
            "tin"
          ]
        }
      ],
      "extendInfo": {
        "NSAppleEventsUsageDescription": "TiN は Terminal / Finder など外部ウィンドウを snap / wobble / raise するために System Events を使用します。",
        "NSAccessibilityUsageDescription": "TiN は外部ウィンドウの位置とサイズを制御するためにアクセシビリティが必要です。",
        "NSSupportsAutomaticTermination": false,
        "NSSupportsSuddenTermination": false
      }
    },
    "files": [
      "main.js",
      "auto-snap.js",
      "workspace.html",
      "grid-terminal.html",
      "grid-overlay.html",
      "package.json",
      "build/Release/ax_helper.node",
      "node_modules/@xterm/**",
      "node_modules/node-pty/**",
      "!atelierx-plugin/**",
      "!docs/**",
      "!logs/**",
      "!scripts/**"
    ],
    "asarUnpack": [
      "build/Release/ax_helper.node",
      "node_modules/node-pty/**"
    ]
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-addon-api": "^8.7.0",
    "node-pty": "^1.1.0"
  }
}
