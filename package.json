{
  "name": "tin",
  "version": "1.10.0",
  "description": "Terminal workspace manager for macOS & Windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "predev": "node scripts/predev.js",
    "dev": "electron . --dev",
    "build": "electron-builder --mac",
    "predist": "node scripts/build-native.js",
    "prebuild": "node scripts/build-native.js",
    "dist": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never"
  },
  "keywords": [
    "macos",
    "windows",
    "window-manager",
    "terminal",
    "electron",
    "productivity",
    "workspace",
    "tabs",
    "groupy",
    "claude-code"
  ],
  "author": "shigenoburyuto",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.shigenoburyuto.tin",
    "productName": "TiN",
    "afterPack": "scripts/clean-xattr.js",
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dir",
          "arch": "arm64"
        },
        {
          "target": "zip",
          "arch": "arm64"
        }
      ],
      "identity": null,
      "icon": "icon.icns",
      "protocols": [
        {
          "name": "TiN URL",
          "schemes": [
            "tin"
          ]
        }
      ],
      "extendInfo": {
        "NSAppleEventsUsageDescription": "TiN は Terminal / Finder など外部ウィンドウを snap / wobble / raise するために System Events を使用します。",
        "NSAccessibilityUsageDescription": "TiN は外部ウィンドウの位置とサイズを制御するためにアクセシビリティが必要です。",
        "NSWindowManagementUsageDescription": "TiN は外部ウィンドウを別のデスクトップ（Space）に移動するためにウィンドウ管理権限が必要です。",
        "NSScreenCaptureUsageDescription": "TiN は他のアプリのウィンドウをデスクトップ間で移動するために画面収録権限が必要です。",
        "NSSupportsAutomaticTermination": false,
        "NSSupportsSuddenTermination": false
      }
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "icon": "icon_1024.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TiN",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "files": [
      "main.js",
      "auto-snap.js",
      "win-helper.js",
      "workspace.html",
      "grid-terminal.html",
      "grid-overlay.html",
      "package.json",
      "build/Release/ax_helper.node",
      "node_modules/@xterm/**",
      "node_modules/node-pty/**",
      "node_modules/koffi/**",
      "!atelierx-plugin/**",
      "!docs/**",
      "!logs/**",
      "!scripts/**"
    ],
    "asarUnpack": [
      "build/Release/ax_helper.node",
      "node_modules/node-pty/**",
      "node_modules/koffi/**"
    ]
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "playwright-core": "^1.59.1"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "koffi": "2.12.0",
    "node-addon-api": "^8.7.0",
    "node-pty": "^1.1.0"
  }
}
